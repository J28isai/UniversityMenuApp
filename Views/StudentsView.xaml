<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="UniversityMenuApp.Views.StudentsView"
             Height="359" Width="498">
    <Grid Margin="24">
        <TextBlock Text="Mantenimiento de Alumnos" FontSize="15" FontWeight="SemiBold"/>
        <TextBlock Margin="0,10,0,0" Text="Pantalla en construcción."/>
        <DataGrid ItemsSource="{Binding Alumnos}"
                  Margin="33,143,62,44"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="60"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="60"/>
            </DataGrid.Columns>
            </DataGrid>
            <TextBox TextWrapping="Wrap" Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="42,92,288,201" />
        <TextBox HorizontalAlignment="Left" Margin="225,92,0,0" TextWrapping="Wrap" Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="120" RenderTransformOrigin="0.293,0.741"/>
        <Label Content="Nombre&#xD;&#xA;" HorizontalAlignment="Left" Margin="63,67,0,0" VerticalAlignment="Top"/>
        <Label Content="Email" HorizontalAlignment="Left" Height="25" Margin="243,67,0,0" VerticalAlignment="Top" Width="54"/>


    </Grid>
</UserControl>